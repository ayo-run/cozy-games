{
  "name": "@cozy-games/utils",
  "version": "0.0.2",
  "description": "Shared, dependency-free browser utilities for Cozy Games (storage, timer, logger, loading, date buckets)",
  "author": "Ayo Ayco",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/ayo-run/mnswpr"
  },
  "main": "index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./*.js": {
      "types": "./*.d.ts",
      "default": "./*.js"
    },
    "./*": {
      "default": "./*"
    }
  },
  "license": "MIT"
}
